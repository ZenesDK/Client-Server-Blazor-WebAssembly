<button @onclick="ToggleTheme" class="btn btn-outline-secondary">
    @icon
</button>

@code {
    private string icon = "🌙";
    
    [Inject] 
    private IJSRuntime JS { get; set; } = default!;
    
    private async Task ToggleTheme()
    {
        var isDark = await JS.InvokeAsync<bool>("eval", "document.documentElement.classList.toggle('dark-mode')");
        icon = isDark ? "☀️" : "🌙";
    }
}
<button @onclick="ToggleTheme" class="btn btn-outline-secondary">
    @icon
</button>

@code {
    private string icon = "🌙";
    
    [Inject] private ThemeService ThemeService { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var isDark = await ThemeService.IsDarkModeAsync();
        icon = isDark ? "☀️" : "🌙";
        // Применяем тему при первой загрузке
        await ThemeService.SetThemeAsync(isDark); 
    }

    private async Task ToggleTheme()
    {
        await ThemeService.ToggleThemeAsync();
        icon = await ThemeService.IsDarkModeAsync() ? "☀️" : "🌙";
    }
}